# =============================================================================
# Amazon PPC Manager Training Program — Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Database
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (PostgreSQL via Docker Compose):
#   docker compose up -d db
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ppc-companion"
#   Run: npm run db:migrate
#
# PRODUCTION (PostgreSQL via Neon / RDS / Supabase):
#   DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
#   Run: npm run db:migrate:prod
#
# IMPORTANT:
#   - schema.prisma uses provider = "postgresql" — all environments use PostgreSQL
#   - No schema swap needed; SQLite parallel schema was removed
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ppc-companion"

# JWT Authentication
# ─────────────────────────────────────────────────────────────────────────────
# Generate a secure random secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-random-64-char-hex-string-in-production"

# Server
PORT=3000
NODE_ENV=development

# Production
# ─────────────────────────────────────────────────────────────────────────────
# APP_URL — set this in production to enable CSRF origin validation
# APP_URL="https://your-app.vercel.app"

# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────
# RATE_LIMIT_MAX — max requests per minute per IP (default: 20)
# RATE_LIMIT_MAX=20

# =============================================================================
# PPC Companion → Project Amazon PH Academy Sampler Handoff (NON-SECRET config only)
# =============================================================================
# PPC Companion is a sampler that links out to the Project Amazon PH Academy
# for the full course. These values are public (NEXT_PUBLIC_*) and hold NO
# secrets. They only build a measurable redirect URL — PPC Companion never
# queries the Academy's DB or shares its auth session.
#
# Project Amazon PH Academy primary destination for sampler completers
# (course comparison page, NOT checkout):
NEXT_PUBLIC_PAPH_APP_URL="https://academy.projectamazonph.com"
#
# Path on the Academy app that sampler completers land on. Always the public
# comparison/course page — never straight to checkout.
NEXT_PUBLIC_PAPH_COMPARE_PATH="/course-comparison"
#
# Non-secret campaign identifier used for attribution (source/medium/campaign).
# Explicit production value: "va-ppc-starter"
NEXT_PUBLIC_PAPH_SAMPLER_CAMPAIGN="va-ppc-starter"
#
# Optional. Set to "1" to log sampler analytics events to the server console
# for local debugging. Leave unset in production (events are silently dropped).
# SAMPLER_ANALYTICS_DEBUG=1
