# =============================================================================
# Amazon PPC Manager Training Program — Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Database
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT (SQLite):
#   DATABASE_URL="file:./db/custom.db"
#   Then copy prisma/schema.sqlite.prisma → prisma/schema.prisma
#   Run: npm run db:migrate
#
# PRODUCTION (PostgreSQL via Neon / RDS / Supabase):
#   DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
#   Schema.prisma defaults to PostgreSQL — no swap needed.
#   Run: npm run db:migrate:prod
#
# IMPORTANT:
#   - schema.prisma defaults to PostgreSQL (for Vercel/production)
#   - schema.sqlite.prisma is the SQLite copy (for local dev)
#   - Swap schema.prisma to the SQLite version for local development
DATABASE_URL="file:./db/custom.db"

# JWT Authentication
# ─────────────────────────────────────────────────────────────────────────────
# Generate a secure random secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-random-64-char-hex-string-in-production"

# Server
PORT=3000
NODE_ENV=development

# Production
# ─────────────────────────────────────────────────────────────────────────────
# APP_URL — set this in production to enable CSRF origin validation
# APP_URL="https://your-app.vercel.app"

# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────
# RATE_LIMIT_MAX — max requests per minute per IP (default: 20)
# RATE_LIMIT_MAX=20
