// ============================================================================
// Amazon PPC Manager — Companion App Database Schema
// ----------------------------------------------------------------------------
// SQLite + Prisma. Designed for production-grade student management with
// clean expansion paths for future features (cohorts, submissions, audit
// trail, notifications, tagging, etc.).
//
// Design principles:
//   1. Every entity has createdAt + updatedAt timestamps.
//   2. Soft-delete (deletedAt) on entities that should be recoverable.
//   3. Every foreign key has an explicit onDelete policy.
//   4. Indexes on every FK and every commonly-filtered column.
//   5. Enums for fixed-value fields (role, status, etc.).
//   6. JSON fields (String?) for flexible metadata where appropriate.
//   7. Unique constraints where business rules require them.
//   8. Cascading deletes only for tightly-owned children (progress entries,
//      submissions, comments). Cohorts and tags are RESTRICT-deleted.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum StudentStatus {
  ACTIVE
  PAUSED
  GRADUATED
  WITHDRAWN
  PENDING // newly signed up, awaiting instructor approval
}

enum CohortStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum EnrollmentStatus {
  ENROLLED
  COMPLETED
  DROPPED
  EXPELLED
}

enum ExerciseType {
  OPEN          // free-text answer
  CALCULATION   // numeric answer with formula
  DECISION      // multiple-choice with explanations
}

enum QuizQuestionType {
  MCQ       // multiple choice
  NUMERIC   // numeric answer
  OPEN      // open-ended (self-graded)
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  GRADED
  RETURNED
}

enum CapstoneStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  ASSIGNMENT
  GRADE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
}

// ============================================================================
// CORE: STUDENT  (the central user entity)
// ============================================================================

model Student {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String
  // H6 FIX: No default password. All code paths must explicitly set and hash.
  // Seed scripts should use bcrypt.hash("chosen-password", 12).
  password      String
  role          Role          @default(STUDENT)

  // Lifecycle
  status        StudentStatus @default(ACTIVE)
  enrolledAt    DateTime      @default(now())
  graduatedAt   DateTime?
  lastLoginAt   DateTime?
  deletedAt     DateTime?     // soft delete — null = active record

  // Profile
  avatarUrl     String?
  bio           String?
  phone         String?
  timezone      String?       @default("UTC")

  // Training state
  currentPhase  Int           @default(1) // 1-4
  targetAcos    Float         @default(30)
  notes         String?       // instructor notes about this student

  // Phase checkpoint pass flags (v1: gate to unlock next phase)
  phase1Pass    Boolean       @default(false)
  phase2Pass    Boolean       @default(false)
  phase3Pass    Boolean       @default(false)
  phase4Pass    Boolean       @default(false)
  capstoneDone  Boolean       @default(false)

  // Legacy cohort string (kept for back-compat; prefer Enrollment table below)
  cohort        String?

  // Timestamps
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  progress      ProgressEntry[]
  enrollments   Enrollment[]
  submissions   ExerciseSubmission[]
  quizAttempts  QuizAttempt[]
  capstones     CapstoneProject[]
  notifications Notification[]
  comments      Comment[]  @relation("CommentAuthor")  // comments authored by this student
  ta            AuditEntry[]    @relation("AuditActor")
  targetOfAudit AuditEntry[]    @relation("AuditTarget")
  sessions      SessionLog[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([cohort])
  @@index([deletedAt])
}

// ============================================================================
// COHORTS
// ============================================================================

model Cohort {
  id          String        @id @default(cuid())
  code        String        @unique // e.g. "batch-2026-q1"
  name        String
  description String?
  status      CohortStatus  @default(PLANNED)
  startDate   DateTime?
  endDate     DateTime?
  maxStudents Int           @default(50)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  enrollments Enrollment[]

  @@index([code])
  @@index([status])
}

// ============================================================================
// ENROLLMENTS (many-to-many: Student <-> Cohort with status)
// ============================================================================

model Enrollment {
  id          String           @id @default(cuid())
  studentId   String
  cohortId    String
  status      EnrollmentStatus @default(ENROLLED)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  droppedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  cohort      Cohort           @relation(fields: [cohortId], references: [id], onDelete: Restrict)

  @@unique([studentId, cohortId])
  @@index([studentId])
  @@index([cohortId])
  @@index([status])
}

// ============================================================================
// CURRICULUM
// ============================================================================

model Phase {
  id          String   @id @default(cuid())
  number      Int      @unique // 1-4
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modules     Module[]
  quizzes     Quiz[]

  @@index([number])
}

model Module {
  id          String   @id @default(cuid())
  phaseId     String
  code        String   @unique // e.g. "1.1", "2.3"
  title       String
  objective   String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  phase       Phase    @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  exercises   Exercise[]
  quizzes     Quiz[]
  progress    ProgressEntry[]

  @@index([phaseId])
  @@index([code])
  @@index([order])
}

// ============================================================================
// EXERCISES
// ============================================================================

model Exercise {
  id          String       @id @default(cuid())
  moduleId    String
  code        String       @unique // e.g. "1.1A"
  title       String
  description String?
  type        ExerciseType @default(OPEN)
  content     String?      // JSON: exercise body
  modelAnswer String?      // JSON: correct answer(s)
  options     String?      // JSON: for DECISION type
  explanation String?      // JSON: explanation after grading
  order       Int          @default(0)
  points      Int          @default(1)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  module      Module       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  submissions ExerciseSubmission[]

  @@index([moduleId])
  @@index([code])
}

model ExerciseSubmission {
  id          String           @id @default(cuid())
  studentId   String
  exerciseId  String
  answer      String?          // JSON
  status      SubmissionStatus @default(DRAFT)
  score       Float?
  feedback    String?
  submittedAt DateTime?
  gradedAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exercise    Exercise         @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  comments    Comment[]  @relation("SubmissionComments")

  @@unique([studentId, exerciseId])
  @@index([studentId])
  @@index([exerciseId])
  @@index([status])
}

// ============================================================================
// QUIZZES
// ============================================================================

model Quiz {
  id           String   @id @default(cuid())
  moduleId     String
  title        String
  description  String?
  passingScore Int      @default(70)
  timeLimitMin Int?     // null = untimed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  module       Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions    QuizQuestion[]
  attempts     QuizAttempt[]
  phases       Phase[]

  @@index([moduleId])
}

model QuizQuestion {
  id               String           @id @default(cuid())
  quizId           String
  text             String
  type             QuizQuestionType @default(MCQ)
  options          String?          // JSON: for MCQ
  modelAnswer      String?
  acceptableAnswers String?          // JSON: for NUMERIC
  explanation      String?
  order            Int              @default(0)
  points           Int              @default(1)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  quiz             Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  studentId   String
  quizId      String
  score       Int
  total       Int
  percentage  Int
  passed      Boolean
  answers     String?  // JSON
  durationSec Int?
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([quizId])
  @@index([passed])
}

// ============================================================================
// PROGRESS TRACKING
// ============================================================================

model ProgressEntry {
  id            String   @id @default(cuid())
  studentId     String
  moduleId      String
  phaseNumber   Int
  exercisesDone Int      @default(0)
  exercisesTotal Int     @default(0)
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  module        Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([studentId, moduleId])
  @@index([studentId])
  @@index([moduleId])
  @@index([phaseNumber])
}

// ============================================================================
// CAPSTONE PROJECTS
// ============================================================================

model CapstoneProject {
  id          String        @id @default(cuid())
  studentId   String
  title       String
  description String?
  status      CapstoneStatus @default(NOT_STARTED)
  deliverables String?      // JSON
  submittedAt DateTime?
  reviewedAt  DateTime?
  feedback    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
}

// ============================================================================
// NOTIFICATIONS
// ============================================================================

model Notification {
  id        String           @id @default(cuid())
  studentId String
  title     String
  message   String?
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  actionUrl String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([read])
  @@index([type])
}

// ============================================================================
// COMMENTS (on exercise submissions)
// ============================================================================

model Comment {
  id            String   @id @default(cuid())
  authorId      String
  submissionId  String
  content       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  author        Student  @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  submission    ExerciseSubmission @relation("SubmissionComments", fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@index([submissionId])
}

// ============================================================================
// AUDIT LOG
// ============================================================================

model AuditEntry {
  id         String     @id @default(cuid())
  actorId    String?
  action     AuditAction
  entityType String
  entityId   String?
  summary    String?
  details    String?    // JSON
  ipAddress  String?
  createdAt  DateTime   @default(now())

  actor      Student?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  target     Student?   @relation("AuditTarget", fields: [entityId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================================
// SESSION LOG
// ============================================================================

model SessionLog {
  id        String   @id @default(cuid())
  studentId String
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())

  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([createdAt])
}
